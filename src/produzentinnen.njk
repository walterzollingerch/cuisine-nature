---
layout: base.njk
title: Produzent:innen – Cuisine Nature
activePage: produzentinnen
---

<div class="page-hero">
  <img src="{{ produzentinnen.hero_image }}" alt="Frisches Gemüse" />
</div>

<section style="text-align:center; padding: 72px 80px;">
  <div class="section-center">
    <h1 class="section-title" style="font-weight:normal;">Produzent:innen</h1>
    <p class="section-text-large" style="font-style:italic; font-size:1.2rem;">{{ produzentinnen.intro_text }}</p>
  </div>
</section>

<div style="padding: 0 80px 80px;">
  {% for producer in produzentinnen.items %}
  <div class="person-card {{ producer.background }}">
    <div class="card-image">
      <img src="{{ producer.image }}" alt="{{ producer.name }}" />
    </div>
    <div class="card-text">
      <h2 class="person-name">{{ producer.name }}</h2>
      <p class="person-text">{{ producer.text | nl2br | safe }}</p>
      <div class="btn-group">
        <a href="/anfrage/" class="btn">Anfrage senden</a>
      </div>
    </div>
  </div>
  {% endfor %}
</div>
