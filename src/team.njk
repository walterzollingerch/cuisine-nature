---
layout: base.njk
title: Team – Cuisine Nature AG
activePage: team
---

<section style="text-align:center; padding: 100px 80px 72px;">
  <div class="section-center">
    <h1 class="section-title" style="font-weight:normal;">Team</h1>
    <p class="person-text" style="text-align:center;">{{ team.intro }}</p>
  </div>
</section>

<div class="team-grid">
  {% for member in team.members %}
  <div class="team-card">
    {% if member.image %}
    <div class="team-card-image">
      <img src="{{ member.image }}" alt="{{ member.name }}" />
    </div>
    {% endif %}
    <div class="team-card-content">
      <h2 class="person-name">{{ member.name }}</h2>
      <p class="person-text">{{ member.text | nl2br | safe }}</p>
    </div>
  </div>
  {% endfor %}
</div>
