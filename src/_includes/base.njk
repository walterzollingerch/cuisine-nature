<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/styles.css" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 93.7 93.6" width="36" height="36">
        <g>
          <path fill="#fff" d="M31.7,93.6h-9.3c-12.4,0-22.4-10-22.4-22.4V22.4C0,10,10,0,22.4,0h9.3v.9h-9.3C10.5.9.9,10.5.9,22.4v48.8c0,11.9,9.6,21.5,21.5,21.5h9.3v.9Z"/>
          <path fill="#fff" d="M71.3,93.6h-9.3v-.9h9.3c11.9,0,21.5-9.6,21.5-21.5V22.4c0-11.9-9.6-21.5-21.5-21.5h-9.3v-.9h9.3c12.4,0,22.4,10,22.4,22.4v48.8c0,12.4-10,22.4-22.4,22.4Z"/>
        </g>
        <path fill="#fff" d="M48.4,70.6c-3.9,0-7.4-1-10.4-2.9-3-1.9-5.3-4.7-6.9-8.3-1.6-3.6-2.4-7.7-2.4-12.4s.8-8.7,2.5-12.3c1.7-3.6,4-6.4,7-8.5,3-2,6.4-3,10.2-3s4,.3,5.6.8,3.1,1.4,4.3,2.6v-.6c0-.2,0-.4,0-.6v-1.1c0-.4.1-.6.4-.9.2-.2.5-.3.8-.3h1.2c.4,0,.6.1.9.3.2.2.3.5.3.9v3.4c-.2,1.6-.2,2.8-.2,3.5s0,1.9.1,3.5v3.5c0,.3,0,.6-.3.8-.2.2-.5.4-.9.4h-1.4c-.4,0-.6-.1-.9-.3-.2-.2-.3-.5-.3-.8,0-3.6-.7-6.5-2.2-8.7-1.5-2.2-3.8-3.3-6.9-3.3s-4.7.8-6.6,2.5c-1.9,1.7-3.3,4-4.4,7.1-1,3.1-1.5,6.6-1.5,10.6s.5,8,1.5,11.1c1,3.1,2.5,5.5,4.5,7.2,1.9,1.7,4.3,2.5,6.9,2.5s4-.4,5.3-1.1c1.3-.8,2.4-2,3.1-3.7.7-1.7,1.2-4,1.4-6.9,0-.4.2-.6.4-.9.2-.2.5-.3.8-.3h1.2c.4,0,.6.1.9.3.2.2.3.5.3.9s0,.7,0,1.1c0,.4,0,.7,0,1.1,0,.4,0,.8-.1,1.2,0,.4,0,.8,0,1.2,0,.9,0,2,.1,3.2v2.1c0,.4,0,.7-.2,1-.2.2-.5.5-.9.8-2.1,1.2-4.1,2.1-6.1,2.6-2,.5-4.4.8-7,.8Z"/>
      </svg>
    </a>
    <ul class="nav-links">
      <li><a href="/" {% if activePage == 'home' %}class="active"{% endif %}>Home</a></li>
      <li><a href="/produzentinnen/" {% if activePage == 'produzentinnen' %}class="active"{% endif %}>Produzent:innen</a></li>
      <li><a href="/haus-am-see/" {% if activePage == 'haus-am-see' %}class="active"{% endif %}>Haus am See</a></li>
      <li><a href="/produkte/" {% if activePage == 'produkte' %}class="active"{% endif %}>Produkte</a></li>
    </ul>
    <a href="#anfrage" class="nav-btn">Anfrage</a>
  </nav>

  {{ content | safe }}

  <footer id="anfrage">
    <div class="footer-top">
      <div>
        <p class="footer-newsletter-label">Anmelden für Neuigkeiten</p>
        <form class="footer-form" onsubmit="window.open('http://eepurl.com/0ffZ4WLj6E','_blank'); return false;">
          <input type="email" class="footer-input" placeholder="Ihre E-Mail-Adresse" />
          <button type="submit" class="nav-btn">Anmelden</button>
        </form>
        <div class="footer-address">
          <strong>Cuisine nature AG</strong><br />
          Seestrasse 513<br />
          8038 Zürich<br /><br />
          <a href="tel:+41442696236">+41 44 269 62 36</a><br />
          <a href="mailto:events@cuisinenature.ch">events@cuisinenature.ch</a>
        </div>
      </div>
      <div class="footer-right">
        <div class="social-icons">
          <a href="https://www.instagram.com/cuisinenature/" target="_blank" rel="noopener" title="Instagram" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="mailto:events@cuisinenature.ch" title="E-Mail" aria-label="E-Mail">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
        <div class="footer-links">
          <a href="/datenschutz/">AGB's &amp; Datenschutz</a>
          <a href="#">Impressum</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-brand-wrapper">
        <div class="footer-brand">Cuisine Nature</div>
      </div>
      <p class="footer-copy">© 2025 Cuisine nature AG</p>
    </div>
  </footer>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
