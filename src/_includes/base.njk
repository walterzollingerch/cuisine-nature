<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 93.7 93.6" width="36" height="36">
        <g>
          <path fill="#1d1d1b" d="M31.7,93.6h-9.3c-12.4,0-22.4-10-22.4-22.4V22.4C0,10,10,0,22.4,0h9.3v.9h-9.3C10.5.9.9,10.5.9,22.4v48.8c0,11.9,9.6,21.5,21.5,21.5h9.3v.9Z"/>
          <path fill="#1d1d1b" d="M71.3,93.6h-9.3v-.9h9.3c11.9,0,21.5-9.6,21.5-21.5V22.4c0-11.9-9.6-21.5-21.5-21.5h-9.3v-.9h9.3c12.4,0,22.4,10,22.4,22.4v48.8c0,12.4-10,22.4-22.4,22.4Z"/>
        </g>
        <path fill="#1d1d1b" d="M48.4,70.6c-3.9,0-7.4-1-10.4-2.9-3-1.9-5.3-4.7-6.9-8.3-1.6-3.6-2.4-7.7-2.4-12.4s.8-8.7,2.5-12.3c1.7-3.6,4-6.4,7-8.5,3-2,6.4-3,10.2-3s4,.3,5.6.8,3.1,1.4,4.3,2.6v-.6c0-.2,0-.4,0-.6v-1.1c0-.4.1-.6.4-.9.2-.2.5-.3.8-.3h1.2c.4,0,.6.1.9.3.2.2.3.5.3.9v3.4c-.2,1.6-.2,2.8-.2,3.5s0,1.9.1,3.5v3.5c0,.3,0,.6-.3.8-.2.2-.5.4-.9.4h-1.4c-.4,0-.6-.1-.9-.3-.2-.2-.3-.5-.3-.8,0-3.6-.7-6.5-2.2-8.7-1.5-2.2-3.8-3.3-6.9-3.3s-4.7.8-6.6,2.5c-1.9,1.7-3.3,4-4.4,7.1-1,3.1-1.5,6.6-1.5,10.6s.5,8,1.5,11.1c1,3.1,2.5,5.5,4.5,7.2,1.9,1.7,4.3,2.5,6.9,2.5s4-.4,5.3-1.1c1.3-.8,2.4-2,3.1-3.7.7-1.7,1.2-4,1.4-6.9,0-.4.2-.6.4-.9.2-.2.5-.3.8-.3h1.2c.4,0,.6.1.9.3.2.2.3.5.3.9s0,.7,0,1.1c0,.4,0,.7,0,1.1,0,.4,0,.8-.1,1.2,0,.4,0,.8,0,1.2,0,.9,0,2,.1,3.2v2.1c0,.4,0,.7-.2,1-.2.2-.5.5-.9.8-2.1,1.2-4.1,2.1-6.1,2.6-2,.5-4.4.8-7,.8Z"/>
      </svg>
    </a>
    <ul class="nav-links">
      <li><a href="/" {% if activePage == 'home' %}class="active"{% endif %}>Home</a></li>
      <li><a href="/produzentinnen/" {% if activePage == 'produzentinnen' %}class="active"{% endif %}>Produzent:innen</a></li>
      <li><a href="/haus-am-see/" {% if activePage == 'haus-am-see' %}class="active"{% endif %}>Haus am See</a></li>
      <li><a href="/produkte/" {% if activePage == 'produkte' %}class="active"{% endif %}>Produkte</a></li>
    </ul>
    <a href="/anfrage/" class="nav-btn">Anfrage</a>
  </nav>

  {{ content | safe }}

  <footer id="anfrage">

    <div class="footer-newsletter-row">
      <div class="footer-newsletter-left">
        <p class="footer-newsletter-label">Anmelden für Neuigkeiten</p>
        <form class="footer-form" id="newsletter-form">
          <input type="email" id="nl-email" class="footer-input" placeholder="E-MAIL" required />
          <input type="text" id="nl-vorname" class="footer-input" placeholder="VORNAME" required />
          <input type="text" id="nl-nachname" class="footer-input" placeholder="NACHNAME" />
          <button type="submit" class="footer-submit">ANMELDEN</button>
        </form>
        <p id="newsletter-success" style="display:none; margin-top:12px; font-style:italic;">Danke! Bitte bestätigen Sie Ihre Anmeldung per E-Mail.</p>
        <p id="newsletter-error" style="display:none; margin-top:12px; color:#c00;">Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.</p>
      </div>
      <div class="footer-social">
        <a href="https://www.facebook.com" target="_blank" rel="noopener" aria-label="Facebook" class="social-icon-filled">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/cuisinenature/" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon-filled">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/18824498/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon-filled">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-info-row">
      <div class="footer-address">
        Cuisine nature AG<br />
        Seestrasse 513<br />
        8038 Zürich<br /><br />
        <a href="/anfrage/" class="footer-link-underline">Nachricht schreiben</a>
      </div>
      <div class="footer-meta">
        <a href="/datenschutz/" class="footer-link-underline">Datenschutz</a>
        <a href="/impressum/" class="footer-link-underline">Impressum</a>
        <span>© 2026 Cuisine nature AG</span>
      </div>
    </div>

    <div class="footer-bottom">
      <img src="/uploads/CN_Wortmarke_1Z_Schwarz.svg" alt="Cuisine Nature" class="footer-wordmark" />
    </div>

  </footer>

  <script>
    document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const body = {
        email: document.getElementById('nl-email').value,
        vorname: document.getElementById('nl-vorname').value,
        nachname: document.getElementById('nl-nachname').value,
      };
      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          e.target.style.display = 'none';
          document.getElementById('newsletter-success').style.display = 'block';
        } else { throw new Error(); }
      } catch {
        document.getElementById('newsletter-error').style.display = 'block';
      }
    });
  </script>

</body>
</html>
