<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/styles.css" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">C</a>
    <ul class="nav-links">
      <li><a href="/" {% if activePage == 'home' %}class="active"{% endif %}>Home</a></li>
      <li><a href="/produzentinnen/" {% if activePage == 'produzentinnen' %}class="active"{% endif %}>Produzent:innen</a></li>
      <li><a href="/haus-am-see/" {% if activePage == 'haus-am-see' %}class="active"{% endif %}>Haus am See</a></li>
      <li><a href="/produkte/" {% if activePage == 'produkte' %}class="active"{% endif %}>Produkte</a></li>
    </ul>
    <a href="#anfrage" class="nav-btn">Anfrage</a>
  </nav>

  {{ content | safe }}

  <footer id="anfrage">
    <div class="footer-top">
      <div>
        <p class="footer-newsletter-label">Anmelden für Neuigkeiten</p>
        <form class="footer-form" onsubmit="return false;">
          <input type="email" class="footer-input" placeholder="Ihre E-Mail-Adresse" />
          <button type="submit" class="nav-btn">Anmelden</button>
        </form>
        <div class="footer-address">
          <strong>Cuisine Nature</strong><br />
          Musterstrasse 132<br />
          4058 Zürich<br /><br />
          <a href="#" style="text-decoration: underline; font-style: italic;">Rechtliches erfahren</a>
        </div>
      </div>
      <div class="footer-right">
        <div class="social-icons">
          <a href="#" title="Facebook" aria-label="Facebook">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" title="Instagram" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="mailto:info@cuisinature.ch" title="E-Mail" aria-label="E-Mail">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
        <div class="footer-links">
          <a href="#">Datenschutz</a>
          <a href="#">Impressum</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-brand-wrapper">
        <div class="footer-brand">Cuisine Nature</div>
      </div>
      <p class="footer-copy">© 2024 Cuisine Nature</p>
    </div>
  </footer>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
